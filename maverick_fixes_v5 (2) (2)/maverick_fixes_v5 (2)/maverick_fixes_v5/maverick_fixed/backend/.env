# Backend Environment Configuration
# This file contains sensitive credentials - DO NOT COMMIT to git!
# Copy values from MongoDB Atlas → Cluster → Connect → Drivers

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration (Frontend URL)
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas Connection String
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER_URL/DATABASE_NAME?retryWrites=true&w=majority
#cd 
# How to get this:
# 1. Go to MongoDB Atlas → Your Cluster → Connect → Connect your application
# 2. Select "Drivers" tab → Node.js driver
# 3. Copy the connection string
# 4. Replace <USERNAME> with your DB user
# 5. Replace <PASSWORD> with your DB password (URL-encode special chars: @=%40, #=%23, etc)
# 6. Database name is already set to "maverick_certify"
#
# Example (replace with your actual credentials):
# MONGODB_URI=mongodb+srv://admin:myPassword123@cluster0.abc123.mongodb.net/maverick_certify?retryWrites=true&w=majority
#
MONGODB_URI=mongodb+srv://logeshwari:Log123@cluster0.w16v9.mongodb.net/Maverick_Certify?retryWrites=true&w=majority&appName=Cluster0
# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

